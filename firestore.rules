rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - username: string (required, unique)
    //   - role: string (required, enum: Beginner, Admin, Developer, ContentMaker)
    //   - registrationDate: timestamp (required)
    //   - balance: number (required)
    //   - lastIdChange: timestamp (optional)
    //
    // Collection: transactions
    // Fields:
    //   - uid: string (required)
    //   - type: string (required, enum: Deposit, Withdrawal)
    //   - amount: number (required)
    //   - timestamp: timestamp (required)
    //   - description: string (optional)
    //
    // Collection: usernames
    // Document ID: username (lowercase)
    // Fields:
    //   - uid: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
         request.auth.token.email == "urazalinasanali@gmail.com");
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 20 &&
             data.role in ['Beginner', 'Admin', 'Developer', 'ContentMaker'] &&
             data.registrationDate is timestamp &&
             data.balance is number && data.balance >= 0;
    }

    function isValidTransaction(data) {
      return data.uid is string &&
             data.type in ['Deposit', 'Withdrawal'] &&
             data.amount is number && data.amount > 0 &&
             data.timestamp is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.role == 'Beginner' &&
                      request.resource.data.balance == 0;
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && 
                        request.resource.data.registrationDate == resource.data.registrationDate &&
                        (isAdmin() || (request.resource.data.role == resource.data.role))) ||
                       isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidTransaction(request.resource.data);
      allow update, delete: if false;
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
