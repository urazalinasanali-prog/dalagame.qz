{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with role, balance, and registration date.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "username": { "type": "string", "description": "Unique display name" },
        "role": { "type": "string", "enum": ["Beginner", "Admin", "Developer", "ContentMaker"], "description": "User role" },
        "registrationDate": { "type": "string", "format": "date-time", "description": "Account creation date" },
        "balance": { "type": "number", "description": "User balance in Tenge" },
        "lastIdChange": { "type": "string", "format": "date-time", "description": "Last time the user ID was changed" }
      },
      "required": ["uid", "username", "role", "registrationDate", "balance"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "History of balance movements.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "type": { "type": "string", "enum": ["Deposit", "Withdrawal"], "description": "Type of operation" },
        "amount": { "type": "number", "description": "Amount in Tenge" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Time of operation" },
        "description": { "type": "string", "description": "Description of the transaction" }
      },
      "required": ["uid", "type", "amount", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profile documents."
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "Transaction" },
      "description": "User balance history."
    },
    "/usernames/{username}": {
      "schema": "object",
      "description": "Helper collection to enforce username uniqueness."
    }
  }
}
